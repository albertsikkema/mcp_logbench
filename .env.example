# Axiom API tokens (referenced from config.yaml)
AXIOM_PROD_TOKEN=your-production-token
AXIOM_STAGING_TOKEN=your-staging-token

# Azure Entra ID (referenced from config.yaml)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# Logging (optional)
LOG_LEVEL=INFO
LOG_FORMAT=json

# Config file path (optional)
CONFIG_PATH=config.yaml
